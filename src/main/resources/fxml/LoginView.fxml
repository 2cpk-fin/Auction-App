<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.shape.*?>

<StackPane
        xmlns="http://javafx.com/javafx/21"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.auction.app.domains.auth.AuthController"
        prefWidth="900" prefHeight="620"
        style="-fx-background-color: #0E0E12;">

    <!-- ── Background accent circle ── -->
    <Circle radius="320" fill="#1A1830" translateX="-200" translateY="-80"/>
    <Circle radius="180" fill="#13122A" translateX="360" translateY="220"/>

    <!-- ── Two-column card ── -->
    <HBox alignment="CENTER" maxWidth="820" maxHeight="520"
          style="-fx-background-color: #15141F;
                 -fx-background-radius: 20;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.6), 40, 0.3, 0, 8);">

        <!-- LEFT PANEL  – brand / illustration -->
        <VBox prefWidth="340" prefHeight="520" alignment="CENTER" spacing="18"
              style="-fx-background-color: #1F1B38;
                     -fx-background-radius: 20 0 0 20;
                     -fx-padding: 48 36 48 36;">

            <!-- Gavel icon (SVG-like via shapes) -->
            <StackPane>
                <Circle radius="52"
                        style="-fx-fill: linear-gradient(to bottom right, #7C5CFC, #A88BFA);
                               -fx-effect: dropshadow(gaussian, #7C5CFC, 28, 0.5, 0, 0);"/>
                <Text text="⚖" style="-fx-font-size: 44; -fx-fill: white;"/>
            </StackPane>

            <Label text="BidVault"
                   style="-fx-font-family: 'Georgia';
                          -fx-font-size: 32;
                          -fx-font-weight: bold;
                          -fx-text-fill: #EDE9FF;
                          -fx-letter-spacing: 2;"/>

            <Label text="The premium auction\nplatform for collectors."
                   textAlignment="CENTER"
                   wrapText="true"
                   style="-fx-font-family: 'Georgia';
                          -fx-font-size: 13;
                          -fx-text-fill: #9E96C8;
                          -fx-text-alignment: center;"/>

            <Region VBox.vgrow="ALWAYS"/>

            <!-- Decorative divider -->
            <HBox spacing="8" alignment="CENTER">
                <Rectangle width="40" height="1" fill="#3D3560"/>
                <Circle radius="3" fill="#7C5CFC"/>
                <Rectangle width="40" height="1" fill="#3D3560"/>
            </HBox>

            <Label text="New here?"
                   style="-fx-font-family: 'Georgia';
                          -fx-font-size: 12;
                          -fx-text-fill: #7069A0;"/>
            <Button text="Create an account →"
                    onAction="#goToRegister"
                    style="-fx-background-color: transparent;
                           -fx-border-color: #7C5CFC;
                           -fx-border-radius: 8;
                           -fx-border-width: 1.5;
                           -fx-text-fill: #A88BFA;
                           -fx-font-family: 'Georgia';
                           -fx-font-size: 12;
                           -fx-padding: 8 20;
                           -fx-cursor: hand;"/>
        </VBox>

        <!-- RIGHT PANEL  – login form -->
        <VBox prefWidth="480" prefHeight="520" alignment="TOP_CENTER" spacing="0"
              style="-fx-padding: 52 52 40 52;">

            <Label text="Welcome back"
                   style="-fx-font-family: 'Georgia';
                          -fx-font-size: 26;
                          -fx-font-weight: bold;
                          -fx-text-fill: #EDE9FF;"/>
            <Label text="Sign in to continue bidding"
                   style="-fx-font-family: 'Georgia';
                          -fx-font-size: 13;
                          -fx-text-fill: #6B6490;
                          -fx-padding: 4 0 28 0;"/>

            <!-- Email -->
            <Label text="EMAIL"
                   style="-fx-font-family: 'Georgia';
                          -fx-font-size: 10;
                          -fx-text-fill: #7C5CFC;
                          -fx-letter-spacing: 2;
                          -fx-padding: 0 0 6 0;"/>
            <TextField fx:id="loginEmailField"
                       promptText="you@example.com"
                       style="-fx-background-color: #1F1B38;
                              -fx-background-radius: 8;
                              -fx-border-color: #2E2A4A;
                              -fx-border-radius: 8;
                              -fx-border-width: 1.5;
                              -fx-text-fill: #EDE9FF;
                              -fx-prompt-text-fill: #4A4470;
                              -fx-font-family: 'Georgia';
                              -fx-font-size: 13;
                              -fx-padding: 12 14;"/>
            <Region prefHeight="16"/>

            <!-- Password -->
            <Label text="PASSWORD"
                   style="-fx-font-family: 'Georgia';
                          -fx-font-size: 10;
                          -fx-text-fill: #7C5CFC;
                          -fx-letter-spacing: 2;
                          -fx-padding: 0 0 6 0;"/>
            <PasswordField fx:id="loginPasswordField"
                           promptText="••••••••"
                           style="-fx-background-color: #1F1B38;
                                  -fx-background-radius: 8;
                                  -fx-border-color: #2E2A4A;
                                  -fx-border-radius: 8;
                                  -fx-border-width: 1.5;
                                  -fx-text-fill: #EDE9FF;
                                  -fx-prompt-text-fill: #4A4470;
                                  -fx-font-family: 'Georgia';
                                  -fx-font-size: 13;
                                  -fx-padding: 12 14;"/>
            <Region prefHeight="10"/>

            <!-- Error label -->
            <Label fx:id="loginErrorLabel"
                   visible="false"
                   wrapText="true"
                   style="-fx-text-fill: #FF6B6B;
                          -fx-font-family: 'Georgia';
                          -fx-font-size: 12;
                          -fx-padding: 4 0;"/>
            <Region prefHeight="18"/>

            <!-- Login button -->
            <Button fx:id="loginButton"
                    text="Sign In"
                    maxWidth="Infinity"
                    onAction="#handleLogin"
                    style="-fx-background-color: linear-gradient(to right, #7C5CFC, #A88BFA);
                           -fx-background-radius: 10;
                           -fx-text-fill: white;
                           -fx-font-family: 'Georgia';
                           -fx-font-size: 14;
                           -fx-font-weight: bold;
                           -fx-padding: 13 0;
                           -fx-cursor: hand;
                           -fx-effect: dropshadow(gaussian, #7C5CFC, 18, 0.3, 0, 4);"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Label text="© 2025 BidVault — All rights reserved"
                   style="-fx-font-family: 'Georgia';
                          -fx-font-size: 10;
                          -fx-text-fill: #3A364F;"/>
        </VBox>
    </HBox>
</StackPane>
