<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.app.views.CreateAuctionViewController"
      prefWidth="1000" prefHeight="800"
      style="-fx-background-color: #FFFFFF; -fx-font-family: 'Segoe UI', sans-serif;">

    <!-- TOP HEADER -->
    <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-padding: 20; -fx-border-color: #E2E8F0 transparent transparent transparent;">
        <Button text="← Back" onAction="#handleGoBack"
                style="-fx-padding: 8 16; -fx-font-size: 13; -fx-background-color: #F1F5F9; -fx-border-radius: 6;"/>
        <Label text="Create Auction" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #0F172A;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <ProgressIndicator fx:id="loadingIndicator" prefWidth="40" prefHeight="40" visible="false"/>
    </HBox>

    <!-- MAIN CONTENT -->
    <HBox spacing="20" style="-fx-padding: 20;" VBox.vgrow="ALWAYS">

        <!-- LEFT PANEL: Products & Auctions -->
        <VBox spacing="15" HBox.hgrow="ALWAYS">

            <!-- Search Bar -->
            <TextField fx:id="searchField"
                       promptText="Search your products..."
                       style="-fx-padding: 10 15; -fx-font-size: 13; -fx-background-color: #F8FAFC; -fx-border-radius: 8;"/>

            <!-- Active Auctions Section -->
            <VBox spacing="10">
                <Label text="Active Auctions" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #0F172A;"/>
                <ScrollPane fx:id="auctionsScrollPane" prefHeight="120" fitToWidth="true"
                           style="-fx-background-color: transparent; -fx-border-color: #E2E8F0; -fx-border-radius: 8;">
                    <HBox fx:id="auctionsContainer" spacing="10" style="-fx-padding: 10; -fx-background-color: #FFFFFF;"/>
                </ScrollPane>
            </VBox>

            <!-- Product Grid Section -->
            <VBox spacing="10" VBox.vgrow="ALWAYS">
                <Label text="Your Products" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #0F172A;"/>
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                           style="-fx-background-color: transparent; -fx-border-color: #E2E8F0; -fx-border-radius: 8;">
                    <FlowPane fx:id="productGrid" hgap="15" vgap="15" style="-fx-padding: 15; -fx-background-color: #FFFFFF;"
                             alignment="TOP_LEFT" prefWrapLength="700"/>
                </ScrollPane>
            </VBox>
        </VBox>

        <!-- RIGHT PANEL: Auction Creation Form -->
        <VBox fx:id="formPanel" spacing="15" style="-fx-border-color: #E2E8F0; -fx-border-left: 2; -fx-padding: 20; -fx-pref-width: 280;"
              visible="false">
            <Label text="Create Auction" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #0F172A;"/>

            <!-- Selected Product -->
            <VBox spacing="5" style="-fx-background-color: #F8FAFC; -fx-padding: 10; -fx-border-radius: 6;">
                <Label text="Selected Product" style="-fx-font-size: 11; -fx-text-fill: #64748B;"/>
                <Label fx:id="selectedProductNameLabel" text="None"
                       style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #0F172A;"/>
            </VBox>

            <!-- Auction Type -->
            <VBox spacing="5">
                <Label text="Auction Type" style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #64748B;"/>
                <ComboBox fx:id="auctionTypeCombo" prefWidth="260"
                         style="-fx-padding: 8 12; -fx-font-size: 12;"/>
            </VBox>

            <!-- BIN Price -->
            <VBox spacing="5">
                <Label text="BIN Price ($)" style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #64748B;"/>
                <TextField fx:id="binPriceField" promptText="e.g., 100"
                          style="-fx-padding: 8 12; -fx-font-size: 12; -fx-background-color: #F8FAFC;"/>
            </VBox>

            <!-- Starting Bid -->
            <VBox spacing="5">
                <Label text="Starting Bid ($)" style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #64748B;"/>
                <TextField fx:id="startingBidField" promptText="e.g., 50"
                          style="-fx-padding: 8 12; -fx-font-size: 12; -fx-background-color: #F8FAFC;"/>
            </VBox>

            <!-- Duration -->
            <VBox spacing="5">
                <Label text="Duration" style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #64748B;"/>
                <ComboBox fx:id="durationCombo" prefWidth="260"
                         style="-fx-padding: 8 12; -fx-font-size: 12;"/>
            </VBox>

            <!-- Category -->
            <VBox spacing="5">
                <Label text="Category" style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #64748B;"/>
                <TextField fx:id="categoryField" promptText="Category"
                          style="-fx-padding: 8 12; -fx-font-size: 12; -fx-background-color: #F8FAFC;"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <!-- Submit Button -->
            <Button fx:id="submitButton" text="Create Auction" onAction="#handleSubmit"
                   style="-fx-padding: 10 16; -fx-font-size: 13; -fx-background-color: #4F46E5; -fx-text-fill: #FFFFFF;
                          -fx-border-radius: 6; -fx-font-weight: bold; -fx-cursor: hand;"/>
        </VBox>
    </HBox>
</VBox>
