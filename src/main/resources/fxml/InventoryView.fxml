<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"   
      fx:controller="com.auction.app.views.InventoryController"
      prefWidth="480" prefHeight="800"
      style="-fx-background-color: #FFFFFF; -fx-font-family: 'Segoe UI', sans-serif; -fx-padding: 16;">

    <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 8 0 12 0;">
        <Button fx:id="backButton" text="← Back" onAction="#handleBack"
                style="-fx-padding: 8 12; -fx-font-size: 13; -fx-background-color: #F1F5F9; -fx-border-radius: 6; -fx-cursor: hand;"/>
        <Label text="Inventory" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #0F172A;"/>
    <Label fx:id="debugLabel" text="" style="-fx-font-size: 11; -fx-text-fill: #94A3B8; -fx-padding: 0 0 0 12;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="addSamplesButton" text="Add Sample Items" onAction="#handleAddSamples"
                style="-fx-background-color: #4F46E5; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 6 12;"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-border-color: transparent;">
        <FlowPane fx:id="inventoryFlow" hgap="12" vgap="12" style="-fx-padding: 8;" prefWrapLength="420"/>
    </ScrollPane>

</VBox>
