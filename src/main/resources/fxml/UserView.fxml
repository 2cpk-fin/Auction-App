<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.shape.*?>

<StackPane
        xmlns="http://javafx.com/javafx/21"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.auction.app.views.UserController"
        prefWidth="400" prefHeight="800"
        style="-fx-background-color: #FFFFFF; -fx-font-family: 'Segoe UI', Helvetica, sans-serif;">

    <VBox spacing="0">
        <!-- ── TOP APP BAR ── -->
    <HBox alignment="CENTER_LEFT" spacing="15"
          style="-fx-background-color: #FFFFFF;
             -fx-padding: 16 24;
             -fx-border-color: transparent transparent #F1F5F9 transparent;
             -fx-border-width: 0 0 1 0;">
        <Button onAction="#goBack" text="← Back"
            style="-fx-padding: 8 12; -fx-font-size: 13; -fx-background-color: #F1F5F9; -fx-border-radius: 6; -fx-cursor: hand;"/>
            <Label text="Profile"
                   style="-fx-font-size: 20; -fx-text-fill: #0F172A;"/>
        </HBox>

        <!-- ── SCROLLABLE CONTENT ── -->
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: #FFFFFF;"
                    vbarPolicy="NEVER" hbarPolicy="NEVER">
            <VBox spacing="24" style="-fx-padding: 30 24;">

                <!-- User Avatar Header -->
                <VBox alignment="CENTER" spacing="0">
                    <StackPane>
                        <Circle radius="40" fill="#EEF2FF"/>
                        <Text text="👤" style="-fx-font-size: 36; -fx-fill: #4F46E5;"/>
                    </StackPane>
                    <Label text="Manage your account"
                           style="-fx-font-size: 14; -fx-text-fill: #64748B; -fx-padding: 12 0 0 0;"/>
                    <Label fx:id="messageLabel" text="Ready"
                           style="-fx-text-fill: #94A3B8; -fx-font-size: 12; -fx-padding: 5 0 0 0;"/>
                </VBox>

                <!-- Form Fields -->
                <VBox spacing="20">

                    <!-- Username Group -->
                    <VBox spacing="6">
                        <Label text="Username" style="-fx-font-size: 11; -fx-text-fill: #475569;"/>
                        <HBox spacing="10">
                            <TextField fx:id="usernameField" promptText="Your username" HBox.hgrow="ALWAYS"
                                       style="-fx-background-color: #F8FAFC; -fx-background-radius: 10; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-border-width: 1; -fx-padding: 12; -fx-text-fill: #0F172A;"/>
                            <Button text="Save" onAction="#onUpdateUsername"
                                    style="-fx-background-color: #4F46E5; -fx-text-fill: #FFFFFF; -fx-background-radius: 10; -fx-padding: 0 20; -fx-cursor: hand; -fx-font-size: 13;"/>
                        </HBox>
                    </VBox>

                    <!-- Email Group -->
                    <VBox spacing="6">
                        <Label text="Email Address" style="-fx-font-size: 11; -fx-text-fill: #475569;"/>
                        <HBox spacing="10">
                            <TextField fx:id="emailField" promptText="Your email" HBox.hgrow="ALWAYS"
                                       style="-fx-background-color: #F8FAFC; -fx-background-radius: 10; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-border-width: 1; -fx-padding: 12; -fx-text-fill: #0F172A;"/>
                            <Button text="Save" onAction="#onUpdateEmail"
                                    style="-fx-background-color: #4F46E5; -fx-text-fill: #FFFFFF; -fx-background-radius: 10; -fx-padding: 0 20; -fx-cursor: hand; -fx-font-size: 13;"/>
                        </HBox>
                    </VBox>

                    <!-- Password Group -->
                    <VBox spacing="6">
                        <Label text="New Password" style="-fx-font-size: 11; -fx-text-fill: #475569;"/>
                        <HBox spacing="10">
                            <PasswordField fx:id="passwordField" promptText="Optional" HBox.hgrow="ALWAYS"
                                           style="-fx-background-color: #F8FAFC; -fx-background-radius: 10; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-border-width: 1; -fx-padding: 12; -fx-text-fill: #0F172A;"/>
                            <Button text="Update" onAction="#onUpdatePassword"
                                    style="-fx-background-color: #8B5CF6; -fx-text-fill: #FFFFFF; -fx-background-radius: 10; -fx-padding: 0 14; -fx-cursor: hand; -fx-font-size: 13;"/>
                        </HBox>
                    </VBox>
                </VBox>

                <Separator style="-fx-background-color: transparent; -fx-border-color: #F1F5F9; -fx-border-width: 1 0 0 0; -fx-padding: 10 0;"/>

                <!-- Danger / Account Actions -->
                <VBox spacing="12">
                    <Button text="Log Out" onAction="#handleLogout" maxWidth="Infinity"
                            style="-fx-background-color: #0F172A; -fx-background-radius: 10; -fx-text-fill: #FFFFFF; -fx-padding: 14; -fx-cursor: hand; -fx-font-size: 14;"/>

                    <Button text="Delete Account" onAction="#onDeleteAccount" maxWidth="Infinity"
                            style="-fx-background-color: transparent; -fx-border-color: #EF4444; -fx-border-width: 1; -fx-border-radius: 10; -fx-text-fill: #EF4444; -fx-padding: 14; -fx-cursor: hand; -fx-font-size: 14;"/>
                </VBox>

            </VBox>
        </ScrollPane>
    </VBox>
</StackPane>