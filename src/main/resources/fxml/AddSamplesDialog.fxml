<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.app.views.AddSamplesController" spacing="10" style="-fx-padding: 12; -fx-background-color: #FFFFFF;">

    <Label text="Select sample items to add" style="-fx-font-size: 16; -fx-font-weight: bold;"/>

    <ScrollPane fitToWidth="true" prefHeight="300">
        <VBox fx:id="itemsContainer" spacing="8" style="-fx-padding: 8;"/>
    </ScrollPane>

    <HBox spacing="8" alignment="CENTER_RIGHT">
        <Button text="Cancel" onAction="#handleCancel"/>
        <Button text="Add Selected" onAction="#handleAdd" style="-fx-background-color: #4F46E5; -fx-text-fill: white;"/>
    </HBox>

</VBox>
