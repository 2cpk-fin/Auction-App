<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.shape.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.app.views.HomeController"
      prefWidth="400" prefHeight="800"
      style="-fx-background-color: #FFFFFF; -fx-font-family: 'Segoe UI', sans-serif;">

    <!-- TOP HEADER -->
    <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-padding: 30 20 10 20;">
        <StackPane onMouseClicked="#goToProfile" style="-fx-cursor: hand;">
            <Circle radius="22" fill="#EEF2FF"/>
            <Text text="👤" style="-fx-font-size: 18; -fx-fill: #4F46E5;"/>
        </StackPane>
        <VBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
            <Label fx:id="welcomeLabel" text="Hi, Bidder" style="-fx-font-size: 18; -fx-font-weight: Bold; -fx-text-fill: #0F172A;"/>
        </VBox>
    </HBox>

    <ScrollPane fitToWidth="true" vbarPolicy="NEVER" hbarPolicy="NEVER" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-border-color: transparent;">
        <VBox spacing="30" style="-fx-padding: 10 20;">

            <!-- MIDDLE: 4 SQUARES GRID -->
            <GridPane hgap="15" vgap="15" alignment="CENTER">
                <columnConstraints>
                    <ColumnConstraints percentWidth="50"/>
                    <ColumnConstraints percentWidth="50"/>
                </columnConstraints>

                <!-- History -->
                <VBox GridPane.columnIndex="0" GridPane.rowIndex="0" alignment="CENTER" spacing="10"
                      style="-fx-background-color: #F8FAFC; -fx-background-radius: 20; -fx-padding: 25; -fx-cursor: hand;">
                    <Text text="🕒" style="-fx-font-size: 30;"/>
                    <Label text="History" style="-fx-font-size: 13; -fx-font-weight: bold;"/>
                </VBox>

                <!-- Create Auction -->
                <VBox GridPane.columnIndex="1" GridPane.rowIndex="0" alignment="CENTER" spacing="10"
                      onMouseClicked="#goToCreateAuction"
                      style="-fx-background-color: #F8FAFC; -fx-background-radius: 20; -fx-padding: 25; -fx-cursor: hand;">
                    <Text text="➕" style="-fx-font-size: 30;"/>
                    <Label text="Create Auction" style="-fx-font-size: 13; -fx-font-weight: bold;"/>
                </VBox>

            <!-- Market -->
            <VBox GridPane.columnIndex="0" GridPane.rowIndex="1" alignment="CENTER" spacing="10"
                onMouseClicked="#goToMarket"
                style="-fx-background-color: #F8FAFC; -fx-background-radius: 20; -fx-padding: 25; -fx-cursor: hand;">
                    <Text text="🛒" style="-fx-font-size: 30;"/>
                    <Label text="Market" style="-fx-font-size: 13; -fx-font-weight: bold;"/>
                </VBox>

                <!-- Registered Auctions -->
                <VBox GridPane.columnIndex="1" GridPane.rowIndex="1" alignment="CENTER" spacing="10"
                      style="-fx-background-color: #F8FAFC; -fx-background-radius: 20; -fx-padding: 25; -fx-cursor: hand;">
                    <Text text="📋" style="-fx-font-size: 30;"/>
                    <Label text="Registered" style="-fx-font-size: 13; -fx-font-weight: bold;"/>
                </VBox>
            </GridPane>

        </VBox>
    </ScrollPane>

    <!-- BOTTOM NAVIGATION -->
    <HBox alignment="CENTER" spacing="35"
          style="-fx-background-color: #FFFFFF; -fx-padding: 15 10 25 10; -fx-border-color: #F1F5F9 transparent transparent transparent;">

        <VBox alignment="CENTER" spacing="4" style="-fx-cursor: hand;">
            <Text text="🏠" style="-fx-font-size: 20; -fx-fill: #4F46E5;"/>
            <Label text="Home" style="-fx-font-size: 11; -fx-text-fill: #4F46E5;"/>
        </VBox>

        <VBox alignment="CENTER" spacing="4" style="-fx-cursor: hand;">
            <Text text="📊" style="-fx-font-size: 20; -fx-fill: #94A3B8;"/>
            <Label text="Overview" style="-fx-font-size: 11; -fx-text-fill: #94A3B8;"/>
        </VBox>

        <VBox alignment="CENTER" spacing="4" onMouseClicked="#goToInventory" style="-fx-cursor: hand;">
            <Text text="🎒" style="-fx-font-size: 20; -fx-fill: #94A3B8;"/>
            <Label text="Inventory" style="-fx-font-size: 11; -fx-text-fill: #94A3B8;"/>
        </VBox>

        <VBox alignment="CENTER" spacing="4" onMouseClicked="#goToProfile" style="-fx-cursor: hand;">
            <Text text="⚙" style="-fx-font-size: 20; -fx-fill: #94A3B8;"/>
            <Label text="Settings" style="-fx-font-size: 11; -fx-text-fill: #94A3B8;"/>
        </VBox>
    </HBox>
</VBox>