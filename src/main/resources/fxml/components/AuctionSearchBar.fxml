<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<fx:root type="javafx.scene.layout.HBox" xmlns="http://javafx.com/javafx/21"
         xmlns:fx="http://javafx.com/fxml/1"
         spacing="10" alignment="CENTER_LEFT"
         style="-fx-padding: 10; -fx-background-color: #F8FAFC; -fx-background-radius: 8;">

    <TextField fx:id="searchField"
               prefWidth="150"
               promptText="Search auctions..."
               style="-fx-padding: 8 12; -fx-font-size: 13;"/>

    <ComboBox fx:id="typeFilter"
              prefWidth="100"
              style="-fx-padding: 8 12; -fx-font-size: 13;"/>

    <Text text="🔍" style="-fx-font-size: 16; -fx-fill: #94A3B8;"/>

    <Region HBox.hgrow="ALWAYS"/>
</fx:root>
