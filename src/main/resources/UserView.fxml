<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.app.domains.user.UserController"
      style="-fx-background-color: #f4f4f4;">

    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <Label text="User Profile Settings">
        <font>
            <Font name="System Bold" size="24.0" />
        </font>
    </Label>

    <GridPane hgap="15.0" vgap="15.0" alignment="CENTER">
        <columnConstraints>
            <ColumnConstraints hgrow="SOMETIMES" minWidth="100.0" prefWidth="120.0" />
            <ColumnConstraints hgrow="SOMETIMES" minWidth="200.0" prefWidth="250.0" />
            <ColumnConstraints hgrow="SOMETIMES" minWidth="100.0" prefWidth="120.0" />
        </columnConstraints>

        <children>
            <Label text="Username:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <TextField fx:id="usernameField" promptText="Enter new username" GridPane.columnIndex="1" GridPane.rowIndex="0" />
            <Button mnemonicParsing="false" onAction="#onUpdateUsername" text="Update" GridPane.columnIndex="2" GridPane.rowIndex="0" />

            <Label text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <TextField fx:id="emailField" promptText="Enter new email" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            <Button mnemonicParsing="false" onAction="#onUpdateEmail" text="Update" GridPane.columnIndex="2" GridPane.rowIndex="1" />

            <Label text="Profile Pic URL:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
            <TextField fx:id="profilePicField" promptText="http://image-url.com" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            <Button mnemonicParsing="false" onAction="#onUpdateProfilePicture" text="Update" GridPane.columnIndex="2" GridPane.rowIndex="2" />

            <Label text="Password Verification:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
            <PasswordField fx:id="passwordField" promptText="Required for changes" GridPane.columnIndex="1" GridPane.rowIndex="3" />
            <Button mnemonicParsing="false" onAction="#onUpdatePassword" text="Verify/Update" GridPane.columnIndex="2" GridPane.rowIndex="3" />
        </children>
    </GridPane>

    <Separator prefWidth="200.0" />

    <HBox alignment="CENTER" spacing="20.0">
        <children>
            <Button mnemonicParsing="false" onAction="#onDeleteAccount"
                    style="-fx-background-color: #ff4444; -fx-text-fill: white; -fx-font-weight: bold;"
                    text="DELETE ACCOUNT" />
        </children>
    </HBox>

    <Label fx:id="messageLabel" text="Status: Ready" textFill="#5e5e5e">
        <font>
            <Font size="14.0" />
        </font>
    </Label>

</VBox>